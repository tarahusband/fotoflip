# FotoFlip — Environment Variables
# Copy this file to .env and fill in your values.

# Server
PORT=3456

# AI — at least one of these is required for metadata extraction and listing generation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Image hosting — Cloudinary is required for marketplace CSV exports
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Marketplace integrations (optional)
IMGBB_API_KEY=
ETSY_API_KEY=
ETSY_SHARED_SECRET=

# Image processing (optional)
OUTPUT_BG_COLOR=#FAF6F1

# GitHub image fallback (optional — used only if Cloudinary is unavailable)
GITHUB_TOKEN=
GITHUB_REPO=username/repo-name
